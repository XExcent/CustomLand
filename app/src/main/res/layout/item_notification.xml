<?xml version="1.0" encoding="utf-8"?><!-- 历史记录列表项布局 - 使用颜色资源引用支持夜间模式自动切换 -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/container"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- 左侧图标 -->
        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="图标"
            android:scaleType="fitCenter"
            tools:src="@drawable/ic_receipt" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 上半部分：图标 + 描述 + 主要内容 + 时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- 右侧文本区域 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- 小号描述文本 (content) -->
                    <TextView
                        android:id="@+id/tvLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp"
                        tools:text="取餐码" />

                    <!-- 大号主要内容 (title) -->
                    <TextView
                        android:id="@+id/tvMainContent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/textPrimary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        tools:text="K555" />

                </LinearLayout>

                <!-- 时间 -->
                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/textTertiary"
                    android:textSize="12sp"
                    tools:text="刚刚" />

            </LinearLayout>

            <!-- 下半部分：描述文字 (info) -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/textSecondary"
                android:textSize="14sp"
                tools:text="香辣鸡腿堡\n肯德基" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
